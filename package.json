{
  "name": "novpn",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/db/migrate.ts up",
    "migrate:down": "tsx src/db/migrate.ts down",
    "refresh": "tsx src/cli/refresh.ts",
    "wrangler:dev": "wrangler dev",
    "wrangler:deploy": "wrangler deploy",
    "wrangler:d1:create": "wrangler d1 create novpn",
    "wrangler:d1:migrate": "wrangler d1 migrations apply novpn",
    "wrangler:d1:migrate:remote": "wrangler d1 migrations apply novpn --remote"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^11.7.0",
    "hono": "^4.6.14",
    "kysely": "^0.27.5",
    "kysely-d1": "^0.4.0",
    "node-cron": "^3.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260430.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.86.0"
  },
  "engines": {
    "node": ">=20"
  }
}
