# HTTP server
PORT=3000

# SQLite database file (will be created if missing)
DATABASE_PATH=data/novpn.sqlite

# If set, all /v1 endpoints require: Authorization: Bearer <API_SECRET>
# If unset, the API is fully open.
# API_SECRET=change-me

# Refresh schedule (5-field crontab, server timezone). Default: daily 03:00.
REFRESH_CRON=0 3 * * *

# Disable the in-process scheduler (1/true). Manual /v1/refresh still works.
# DISABLE_CRON=0

# Skip the one-shot refresh of never-fetched providers on startup (1/true).
# DISABLE_REFRESH_ON_START=0

# Per-source HTTP fetch timeout, milliseconds.
FETCH_TIMEOUT_MS=30000

# Max number of IPs accepted in POST /v1/check/batch.
BATCH_CHECK_MAX=1000
